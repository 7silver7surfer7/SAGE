generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_CONNECTION_POOL_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Drop {
  id                               Int         @id @default(autoincrement())
  name                             String
  createdAt                        DateTime    @default(now())
  approvedAt                       DateTime?
  goLiveAt                         DateTime? // staged until this time; null = live once approved
  approvedBy                       String?     @db.Char(42)
  bannerImageS3Path                String
  // Set only when the artist uploaded a VIDEO as the banner: bannerImageS3Path
  // is always a static first-frame poster (most banner surfaces — dashboard
  // cards, this drop's own social post preview thumbnail, etc. — render it
  // as a plain <img> and can't play video), while this holds the real clip
  // for the few surfaces that DO know how to play it (the drop's Twitter-
  // style announcement post on the social feed).
  bannerVideoS3Path                String?
  // Custom ERC-721 ticker/symbol, set at drop creation. Only actually takes
  // effect the FIRST time this drop's artist deploys their shared NFT
  // contract (Open Edition / Auction mint into that one contract, and its
  // symbol is immutable once deployed) — ignored on every later drop by the
  // same artist, since there's nothing left to set. Null = auto-derive from
  // the artist's display name, same as before this field existed.
  nftSymbol                        String?
  description                      String
  mobileCoverS3Path                String?
  tileImageS3Path                  String?
  featuredMediaS3Path              String?
  artistAddress                    String      @db.Char(42)
  // Per-drop artist display name override. Set once at drop creation and
  // frozen — does not track later profile renames or apply to other drops
  // by the same wallet. Null = show the artist's current profile username.
  artistDisplayName                String?
  // Secondary-sale royalty in PERCENT (12 = 12%). Stamped onto the artist's
  // NFT contract as basis points at drop deploy; each token minted for this
  // drop keeps the value permanently. Marketplace re-sales only — primary
  // sale splits are unaffected.
  royaltyPercentage                Float       @default(10)
  // Payment currency for every game in this drop: "SAGE" (the ERC-20) or
  // "ETH" (native). Chosen at creation, baked into the game contracts at
  // deploy (on-chain: address(0) = SAGE, the 0xEeee..EEeE sentinel = ETH).
  currency                         String      @default("SAGE")
  // True for drops created through the SAGE Social self-serve launcher
  // (storage:'filebase' at creation) — distinguishes them from admin-curated
  // marketplace drops so their primary-sale split can differ (99% artist /
  // 1% platform vs the marketplace default) without touching the shared
  // SageConfig dial that marketplace drops still use.
  isSocial                          Boolean     @default(false)
  // Allowlist gating: when enabled, only wallets in AllowlistEntries may
  // mint/bid/buy (on-chain via a per-drop SageWhitelist contract for open
  // editions + lotteries; UI-gate for auctions). Editable pre- and post-deploy.
  allowlistEnabled                 Boolean     @default(false)
  whitelistContractAddress         String?     @db.Char(42) // deployed SageWhitelist; null until approval
  // IP gate: minting requires claiming a spot first (one per IP, hashed) —
  // the claim auto-adds the wallet to the drop's on-chain whitelist, so
  // direct-contract mints from unclaimed wallets revert. Sybil SPEED BUMP,
  // not a wall (VPNs rotate IPs; shared IPs get one spot total).
  ipGateEnabled                    Boolean     @default(false)
  // SAGE Social follow gate: when on, anyone who follows this drop's artist
  // on SAGE Social is auto-added to the drop's allowlist (DB + on-chain).
  followGateEnabled                Boolean     @default(false)
  // Gas-free gating (opt-in): when true, the drop's games deploy on the
  // VOUCHER contracts (voucherGated=true) instead of a per-drop SageWhitelist.
  // Eligibility (allowlist / IP-gate / follow-gate) still populates
  // DropAllowlistEntry, but nothing is written on-chain — the server signs a
  // per-wallet voucher at mint time and the minter redeems it themselves.
  // Zero platform gas. Default false = the classic whitelist path.
  voucherGating                    Boolean     @default(false)
  NftContract                      NftContract @relation("ContractDrops", fields:[artistAddress], references: [artistAddress])
  ApprovedByUser                   User?       @relation("Drop_approvedByToUser", fields: [approvedBy], references: [walletAddress])
  Auctions                         Auction[]
  Lotteries                        Lottery[]
  OpenEditions                     OpenEdition[]
  CollectionMints                  CollectionMint[]
  UserFavoriteDrops                User[]      @relation("userFavoriteDrops")
  FeaturedDropConfig               Config?     @relation("ConfigFeaturedDrop")
  AllowlistEntries                 DropAllowlistEntry[]
}

// First-party visitor analytics: one row per pageview beacon. Privacy-sane —
// visitorId/sessionId are random client-side ids (no fingerprinting), IPs are
// stored only as salted hashes (same pattern as MintIpClaim), and rows are
// pruned after ~90 days. walletAddress links a visit to a signed-in user,
// which powers the visitor→wallet conversion funnel in the admin portal.
model SiteVisit {
  id            Int      @id @default(autoincrement())
  visitorId     String   @db.Char(36)
  sessionId     String   @db.Char(36)
  walletAddress String?  @db.Char(42)
  path          String   @db.VarChar(120)
  referrer      String?  @db.VarChar(120) // host only, never full URLs
  country       String?  @db.Char(2)      // from Cloudflare's cf-ipcountry on prod
  device        String   @db.VarChar(10)  // mobile | tablet | desktop
  ipHash        String?  @db.Char(64)
  createdAt     DateTime @default(now())
  @@index([createdAt])
  @@index([visitorId, createdAt])
  @@index([path])
  @@index([walletAddress])
}

// One row per (drop, network) mint-spot claim for IP-gated drops. The IP is
// stored as a salted hash — never raw. A network gets ONE wallet per drop;
// a wallet gets ONE claim per drop.
model MintIpClaim {
  id            Int      @id @default(autoincrement())
  dropId        Int
  ipHash        String   @db.Char(64) // sha256(salt + client ip), hex
  walletAddress String   @db.Char(42)
  createdAt     DateTime @default(now())
  @@unique([dropId, ipHash])
  @@unique([dropId, walletAddress])
}

// SAGE Social faucet: ONE claim per wallet AND per network, globally (no
// per-drop dimension — unlike MintIpClaim there's only one faucet). A row
// here reserves the claim the moment a voucher is issued, before the
// on-chain tx even lands, so two requests racing from the same IP/wallet
// can't both walk away with a signed voucher.
model FaucetClaim {
  id            Int      @id @default(autoincrement())
  ipHash        String   @unique @db.Char(64) // sha256(salt + client ip), hex
  walletAddress String   @unique @db.Char(42)
  createdAt     DateTime @default(now())
}

// "Collection" drop style: a ZIP of N unique images uploaded in bulk (ANS-104
// bundles + one Arweave path manifest); collectors mint sequentially at a
// fixed SAGE price via the SageCollection contract. Unlike OpenEdition there
// is no upfront Nft row per image — Nft rows materialize per mint (see
// RegisterCollectionMint), keyed off the manifest paths.
model CollectionMint {
  id               Int       @id @default(autoincrement())
  dropId           Int
  collectionId     Int? // on-chain collection id (== id, set at deploy/approval)
  contractAddress  String?   @db.Char(42)
  // Dedicated per-drop SageNFT the collection mints into, named after the
  // DROP — external marketplaces title collections by ERC-721 name(), so
  // this makes each collection drop its own marketplace collection. Null =
  // legacy (minted into the artist's shared contract, e.g. rMonet).
  nftContractAddress String? @db.Char(42)
  // Custom ERC-721 ticker/symbol for the DEDICATED contract this collection
  // deploys (unlike Drop.nftSymbol, this always applies — every ZIP
  // collection gets its own fresh contract). Null = auto-derive from the
  // drop's name, same as before this field existed.
  nftSymbol        String?
  costTokens       Float     @default(0) // mint price in SAGE
  maxSupply        Int // number of images == hard mint cap
  limitPerUser     Int       @default(0) // 0 = unlimited
  mintCount        Int       @default(0) // cached on-chain mint count
  isLive           Boolean   @default(false)
  startTime        DateTime
  endTime          DateTime? // null = NO deadline — mint stays open until sold out
  manifestId       String? // Arweave path-manifest txid (set when processing completes)
  baseUri          String? // https://arweave.net/{manifestId}/ — token i's metadata at {i}.json
  previewImagePath String? // first image's URL, for tiles/cards
  status           String    @default("staging") // staging | processing | done | failed
  progress         String? // JSON: { imagesTotal, imagesBundled, bundlesPosted: [txids], error? }
  // JSON: { "<index>": { img: dataItemId, json: dataItemId, ext: "png" } } —
  // written as processing batches complete; doubles as the resume checkpoint
  // (DataItem ids are NOT reproducible across retries: Arweave RSA-PSS
  // signatures are randomized, so a re-signed item gets a new id) and as the
  // register-time lookup for each minted token's direct image URL.
  pathMap          String?
  Drop             Drop      @relation(fields: [dropId], references: [id])
}

model DropAllowlistEntry {
  id        Int       @id @default(autoincrement())
  dropId    Int
  address   String    @db.Char(42) // stored lowercase
  createdAt DateTime  @default(now())
  syncedAt  DateTime? // null = not yet pushed to the on-chain SageWhitelist
  Drop      Drop      @relation(fields: [dropId], references: [id])

  @@unique([dropId, address])
  @@index([dropId])
}

model Lottery {
  id                          Int        @id @default(autoincrement()) 
  dropId                      Int    
  isRefundable                Boolean    @default(false) 
  isLive                      Boolean    @default(false)
  contractAddress             String?    @db.Char(42)
  costPerTicketTokens         Float      @default(0.0)
  costPerTicketPoints         Int        @default(0)
  maxTickets                  Int        @default(0)
  maxTicketsPerUser           Int        @default(0)
  whitelistId                 Int?
  prizesAwardedAt             DateTime?
  endTime                     DateTime
  startTime                   DateTime
  Drop                        Drop       @relation(fields: [dropId], references: [id])
  Whitelist                   Whitelist?  @relation(fields: [whitelistId], references: [id])
  Nfts                        Nft[]
  PrizeProofs                 PrizeProof[]  
  Refunds                     Refund[] 
}

model OpenEdition {
  id              Int       @id @default(autoincrement())
  dropId          Int
  nftId           Int
  editionId       Int? // on-chain open edition id (set at deploy/approval)
  contractAddress String?   @db.Char(42)
  costTokens      Float     @default(0) // price per mint in SAGE
  costPoints      Int       @default(0) // price per mint in pixels
  maxPerUser      Int       @default(0) // 0 = unlimited
  mintCount       Int       @default(0) // cached on-chain mint count
  isLive          Boolean   @default(false)
  // Gas-free gating: when true this edition lives on OPENEDITION_VOUCHER_ADDRESS
  // and mints ONLY via batchMintWithVoucher (a platform-signed per-wallet
  // voucher). false = the classic whitelist path on OPENEDITION_ADDRESS.
  voucherGated    Boolean   @default(false)
  startTime       DateTime
  endTime         DateTime
  Drop            Drop      @relation(fields: [dropId], references: [id])
  Nft             Nft       @relation(fields: [nftId], references: [id])
  @@unique([nftId])
}

model Auction {
  id                    Int        @id @default(autoincrement())
  dropId                Int        
  lastUpdatedAt         DateTime?
  minimumPrice          String?
  settled               Boolean    @default(false)
  startTime             DateTime
  endTime               DateTime?
  duration              Int?
  isLive                Boolean    @default(false) 
  nftId                 Int 
  winnerAddress         String?     @db.Char(42)
  claimedAt             DateTime?
  contractAddress       String?   @db.Char(42)
  Drop                  Drop @relation(fields: [dropId], references: [id])
  Nft                   Nft  @relation(fields: [nftId], references: [id])
  Bids                  BidHistory[]
  @@unique([nftId])
}

model SplitEntry {
  id                 Int      @id @default(autoincrement())
  destinationAddress String   @db.Char(42)
  splitterId         Int
  percent            Float
  Splitter           Splitter @relation(fields: [splitterId], references: [id])
}

model Splitter {
  id                     Int          @id @default(autoincrement())
  splitterAddress        String?      @db.Char(42)
  NftContract            NftContract[] @relation("Splitter")
  SplitterEntries        SplitEntry[]
}

model Whitelist {
  id               Int              @id @default(autoincrement())
  contractAddress  String           @db.Char(42)
  targetAddress    String?          @db.Char(42)
  tokenId          Int?
  minBalance       Int?
  name             String
  Type             WhitelistType
  Lotteries        Lottery[]
}

model Nft {
  id                       Int          @id @default(autoincrement())
  tokenId                  Int?
  name                     String
  description              String
  metadataPath             String?
  arweavePath              String?
  s3Path                   String
  s3PathOptimized          String
  // "video" | "image" (null = legacy/image). s3Path/s3PathOptimized store
  // the real media either way — this just tells BaseMedia whether it's safe
  // to <video> it, since a Filebase/IPFS URL has no file extension to sniff
  // (unlike an arweave.net tx or a plain .mp4 path).
  mediaType                String?
  tags                     String?
  width                    Int?
  height                   Int?
  numberOfEditions         Int          @default(0)
  isHidden                 Boolean      @default(false)
  lotteryId                Int?
  price                    Float?
  ownerAddress             String?      @db.Char(42)
  artistAddress            String?      @db.Char(42)
  // Snapshot of the parent Drop's artistDisplayName (if any) at the moment
  // this Nft was created — frozen per-NFT for the same reason Drop's own
  // field is frozen: a later profile rename or a different drop by the same
  // wallet shouldn't retroactively change how an already-minted piece is
  // attributed. Null = fall back to the artist's live username.
  artistDisplayName        String?
  PrizeProof               PrizeProof[]
  Auction                  Auction?
  OpenEdition              OpenEdition?
  Lottery                  Lottery?     @relation(fields: [lotteryId], references: [id])
  NftContract              NftContract? @relation(fields: [artistAddress], references: [artistAddress])
  Offers                   Offer[]   
}

model NftContract {
  artistAddress          String  @id @db.Char(42)
  contractAddress        String? @db.Char(42)
  // DEPRECATED — never read; superseded by Drop.royaltyPercentage (per-drop,
  // stamped on-chain at deploy). Kept to avoid a destructive column drop.
  royaltyPercentage      Float       @default(0.0)
  splitterId             Int?
  Splitter               Splitter?   @relation("Splitter", fields: [splitterId], references: [id])
  Artist                 User        @relation("ArtistContract", fields: [artistAddress], references: [walletAddress])
  Drops                  Drop[]  @relation("ContractDrops")
  ListingNfts            Nft[] 
  @@unique([contractAddress])      
}

model PrizeProof {
  winnerAddress String    @db.Char(42)
  proof         String
  claimedAt     DateTime?
  createdAt     DateTime
  nftId         Int
  ticketNumber  Int
  lotteryId     Int
  uri           String
  Nft           Nft       @relation(fields: [nftId], references: [id])
  Lottery       Lottery   @relation(fields: [lotteryId], references: [id])
  User          User      @relation(fields: [winnerAddress], references: [walletAddress])
  @@id([lotteryId, winnerAddress, nftId])
}

model TokenTransaction {
  blockNumber    Int
  blockTimestamp Int
  from           String    @db.Char(42)
  to             String    @db.Char(42)
  value          String
  assetType      AssetType
  id             Int       @id @default(autoincrement())
  txHash         String    @db.Char(66)
  @@index([from, to])
}

model EarnedPoints {
  address           String   @id @db.Char(42)
  totalPointsEarned BigInt   @default(0)
  signedMessage     String
  updatedAt         DateTime @default(now())
  User              User     @relation(fields: [address], references: [walletAddress])
}

model RewardType {
  type               AssetType @id
  rewardRate         Float
  lastBlockInspected Int
  chainId            Int
  contract           String    @db.Char(42)
  startingBlock      Int
  positionSizeLimit  String    @default("0")
  // watermark for the pixels ACCRUAL pass (distinct from lastBlockInspected,
  // which tracks Transfer-event SCANNING): transactions at or below this
  // block are already folded into PixelAccrual rows
  pointsBlockProcessed Int     @default(0)
}

// Per-(holder, asset) pixels checkpoint. The updater used to reload the whole
// TokenTransaction table and replay every holder's full history on every run
// (unbounded, grows forever); with this it folds only NEW transfers into each
// holder's running state. `pixels` is the total accrued through `refTime`
// (the last balance change); live balances keep accruing from there.
model PixelAccrual {
  id        Int       @id @default(autoincrement())
  address   String    @db.Char(42) // lowercase holder address
  assetType AssetType
  balance   String    @default("0") // wei, decimal string
  pixels    Float     @default(0)
  refTime   Int       @default(0) // unix seconds of last balance change; 0 = none yet
  @@unique([address, assetType])
}

model User {
  walletAddress                 String        @id @db.Char(42)
  email                         String?       @db.VarChar(40)
  twitterUsername               String?       @db.VarChar(40)
  instagramUsername             String?       @db.VarChar(40)
  webpage                       String?       @db.VarChar(50)
  mediumUsername                String?       @db.VarChar(40)
  createdAt                     DateTime      @default(now())
  role                          Role          @default(USER)
  bio                           String?       @db.VarChar(1000)
  location                      String?       @db.VarChar(60) // freeform, Twitter-style
  // One pinned post shown at the top of the profile, Twitter-style. Must be
  // one of the user's OWN posts (enforced server-side); null = nothing pinned.
  pinnedPostId                   Int?          @unique
  PinnedPost                     SocialPost?   @relation("PinnedPost", fields: [pinnedPostId], references: [id])
  // Admin moderation: a banned wallet's profile 404s for everyone but admins,
  // their posts drop out of every feed, and every one of their drops is
  // delisted (approvedAt cleared) the moment the ban lands. On-chain state
  // (minted tokens, deployed contracts) is untouched — this is a platform
  // takedown, not a chain-level action.
  bannedAt                       DateTime?
  bannedReason                   String?       @db.VarChar(300)
  bannedBy                       String?       @db.Char(42)
  ashBalanceAtCreation          String        @default("0")
  profilePicture                String?
  country                       String?
  state                         String?
  bannerImageS3Path            	String?
  receiveEmailNotification      Boolean       @default(true)
  username                      String?       @db.VarChar(40)
  // SAGE Social verified pfp: when the avatar was picked from an owned NFT,
  // this points at it. Verification is computed at READ time (owner must
  // still match and profilePicture must still be that NFT's image), so a
  // sold NFT or a custom re-upload silently un-verifies without any cron.
  pfpNftId                      Int?
  // SAGE Social paid verification ($10 in SAGE to the platform treasury):
  // the checkmark + premium features (sell/collect posts, points-collect,
  // boost, DMs). Posting stays free.
  verifiedAt                    DateTime?
  verifiedTxHash                String?       @db.Char(66)
  // Referral gate: the invite code this wallet redeemed to join SAGE Social.
  // Null + role USER + unverified = can browse but not post yet.
  invitedByCode                 String?
  // Set true the moment this wallet ever signs in through sage-mcp (the AI
  // agent MCP server) — see AGENT_SIWE_STATEMENT in [...nextauth].page.ts.
  // Drives the "Agent" badge on SAGE Social so humans aren't fooled into
  // treating an agent-run account as a person. Sticky: never reset to false,
  // since a wallet that has ever driven itself via MCP has demonstrated
  // agent capability regardless of which client signs in next.
  isAgent                        Boolean       @default(false)
  // Last time this wallet opened the Activity tab — drives the Twitter-style
  // unread counter on the Activity nav item (count of likes/reposts/tips/
  // collects/follows/replies directed at them since this timestamp). Null =
  // never opened, so everything counts as unread.
  lastSeenActivityAt             DateTime?
  SocialInviteCodes             SocialInviteCode[] @relation("InviteOwner")
  SocialMessagesSent            SocialMessage[]    @relation("SocialMsgFrom")
  SocialMessagesReceived        SocialMessage[]    @relation("SocialMsgTo")
  SocialPointsSpends            SocialPointsSpend[]
  SocialTokenLaunches           SocialTokenLaunch[]
  SocialGroupChat               SocialGroupChat?
  SocialNftEditions             SocialNftEdition[] @relation("SocialEditions")
  DropsApproved                 Drop[]        @relation("Drop_approvedByToUser")
  NftContract                   NftContract?  @relation("ArtistContract")
  EarnedPoints                  EarnedPoints?
  FavoriteDrops                 Drop[]        @relation("userFavoriteDrops")
  Bids                          BidHistory[]
  PrizeProofs                   PrizeProof[]
  // SAGE Social: wallet == identity for the BlueSky-style network
  SocialPosts                   SocialPost[]    @relation("SocialAuthor")
  SocialLikes                   SocialLike[]
  SocialReposts                 SocialRepost[]
  Following                     SocialFollow[]  @relation("SocialFollower")
  Followers                     SocialFollow[]  @relation("SocialFollowing")
  @@index([walletAddress])
  @@unique([username])
}

// ─────────────────────────── SAGE Social ───────────────────────────
// A wallet-native BlueSky clone: identity is the SIWE wallet, posts can be
// tipped in SAGE tokens, and avatars are the user's (NFT) profilePicture.

model SocialPost {
  id           Int            @id @default(autoincrement())
  authorAddress String        @db.Char(42)
  Author       User           @relation("SocialAuthor", fields: [authorAddress], references: [walletAddress])
  PinnedByUser User?          @relation("PinnedPost")
  text         String         @db.VarChar(500)
  imageUrl     String?        // optional media (S3 URL from /api/social-upload)
  mediaType    String?        // "image" | "video" (null = legacy/image)
  createdAt    DateTime       @default(now())
  // soft delete: history (tips/leaderboards) stays intact, feeds filter it
  // out, GetPost 404s. Posts with collects can NEVER be deleted — the minted
  // NFTs' tokenURI metadata lives at this row.
  deletedAt    DateTime?
  // editing is a VERIFIED-only perk (Twitter Blue style); set on every edit
  // so the card can show an "edited" label
  editedAt     DateTime?
  // reply threading (self-relation); null = top-level post
  replyToId    Int?
  ReplyTo      SocialPost?    @relation("SocialReplies", fields: [replyToId], references: [id], onDelete: Cascade)
  Replies      SocialPost[]   @relation("SocialReplies")
  // denormalized counters kept in sync on write (cheap reads on the feed)
  likeCount    Int            @default(0)
  repostCount  Int            @default(0)
  replyCount   Int            @default(0)
  tipTotal     Float          @default(0) // total SAGE tipped to this post
  tipTotalEth  Float          @default(0) // total native ETH tipped to this post
  // Currency the author sells this post in when collectible ("SAGE" | "ETH"),
  // mirroring the per-drop currency pattern. Points-collect is SAGE-only.
  collectCurrency String      @default("SAGE")
  // burn-to-boost (Twitter-style, SOFT): a boost is a budget × duration
  // campaign that gently lifts the post in the ranked feed for its window,
  // then fades. boostedAt..boostedUntil is the active window; boostStrength
  // (set from the daily budget) is the max soft rank bonus, decayed linearly
  // across the window in getFeed. Verified on-chain server-side (SAGE burn).
  boostedAt    DateTime?
  boostedUntil DateTime?
  boostStrength Float         @default(0)
  boostBurned  Float          @default(0) // lifetime SAGE burned on this post
  // collect-as-NFT: author sets a SAGE price (0 = free collect); each collect
  // pays the author directly and server-mints the post into the platform's
  // "SAGE Social" SageNFT contract.
  collectPrice Float?
  collectCount Int            @default(0)
  // link preview (Twitter-style card): the first URL in the text is unfurled
  // server-side at post time (OG tags / oEmbed) and frozen here
  linkUrl      String?        @db.VarChar(500)
  linkTitle    String?        @db.VarChar(200)
  linkDesc     String?        @db.VarChar(300)
  linkImage    String?        @db.VarChar(500)
  // Twitter-style DROP posts: the post is the storefront — likes/replies/
  // shares work as usual, the CTA drives to the auction/mint
  dropId       Int?
  dropKind     String?        // "auction" | "openEdition" | "collection"
  dropPrice    Float?         // reserve (auction) / mint price, in the drop's currency
  // quote-reposts: a new post that embeds another as a card (self-relation)
  quotedPostId Int?
  Quoted       SocialPost?    @relation("SocialQuotes", fields: [quotedPostId], references: [id], onDelete: SetNull)
  Quotes       SocialPost[]   @relation("SocialQuotes")
  quoteCount   Int            @default(0)
  Likes        SocialLike[]
  Reposts      SocialRepost[]
  Tips         SocialTip[]
  Boosts       SocialBoost[]
  Collects     SocialCollect[]
  @@index([createdAt])
  @@index([authorAddress])
  @@index([replyToId])
  @@index([boostedUntil])
  @@index([quotedPostId])
}

// One row per #tag per post, written at post time — powers tag feeds.
model SocialHashtag {
  id        Int      @id @default(autoincrement())
  postId    Int
  tag       String   @db.VarChar(80)
  createdAt DateTime @default(now())
  @@index([tag, createdAt])
  @@index([postId])
}

model SocialFollow {
  followerAddress  String   @db.Char(42)
  followingAddress String   @db.Char(42)
  createdAt        DateTime @default(now())
  Follower         User     @relation("SocialFollower", fields: [followerAddress], references: [walletAddress])
  Following        User     @relation("SocialFollowing", fields: [followingAddress], references: [walletAddress])
  @@id([followerAddress, followingAddress])
  @@index([followingAddress])
}

model SocialLike {
  postId       Int
  userAddress  String     @db.Char(42)
  createdAt    DateTime   @default(now())
  Post         SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  User         User       @relation(fields: [userAddress], references: [walletAddress])
  @@id([postId, userAddress])
}

model SocialRepost {
  postId       Int
  userAddress  String     @db.Char(42)
  createdAt    DateTime   @default(now())
  Post         SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  User         User       @relation(fields: [userAddress], references: [walletAddress])
  @@id([postId, userAddress])
}

model SocialTip {
  id          Int        @id @default(autoincrement())
  postId      Int
  fromAddress String     @db.Char(42)
  toAddress   String     @db.Char(42)
  amount      Float      // amount in `currency`
  currency    String     @default("SAGE") // "SAGE" | "ETH"
  txHash      String     @db.Char(66) @unique // one credit per on-chain transfer
  createdAt   DateTime   @default(now())
  Post        SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@index([postId])
}

model SocialBoost {
  id          Int        @id @default(autoincrement())
  postId      Int
  fromAddress String     @db.Char(42)
  amount      Float      // SAGE burned
  hours       Float      // boost duration this burn bought
  txHash      String     @db.Char(66) @unique // one credit per on-chain burn
  createdAt   DateTime   @default(now())
  Post        SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@index([postId])
}

// Global registry of on-chain payments TO THE TREASURY that have been
// redeemed for SOME action. PurchaseVerification (User.verifiedTxHash) and
// BoostPost (SocialBoost.txHash) both pay the same TREASURY_ADDRESS but used
// to check uniqueness only against their OWN table — so a single real
// payment could be submitted once as a verification purchase AND once as a
// boost, granting both from one payment. txHash as the primary key makes
// claiming it atomic and global across every treasury-paying action, not
// just within one action's own table.
model SocialTreasuryTxClaim {
  txHash    String   @id @db.Char(66)
  action    String // "PurchaseVerification" | "BoostPost"
  claimedBy String   @db.Char(42)
  createdAt DateTime @default(now())
}

// A pump.fun-style creator coin launched from a SAGE Social profile. Mirrors
// on-chain state (SocialTokenFactory) for the profile buy widget; the chain
// is the source of truth for reserves/price (read live).
model SocialTokenLaunch {
  id              Int      @id @default(autoincrement())
  // creators can launch many tokens; the FIRST (lowest id) is the profile token
  creatorAddress  String   @db.Char(42)
  Creator         User     @relation(fields: [creatorAddress], references: [walletAddress])
  tokenAddress    String   @unique @db.Char(42)
  name            String   @db.VarChar(40)
  symbol          String   @db.VarChar(12)
  launchTxHash    String   @db.Char(66)
  imageUrl        String?  // optional token art (S3)
  bannerUrl       String?  // optional wide banner shown on the token page (pump.fun-style)
  description     String?  @db.VarChar(300) // pump.fun-style one-liner
  website         String?  @db.VarChar(120) // project link shown next to the description
  // Social links, DexScreener token-info style. Editable post-launch by the
  // creator via UpdateTokenInfo (unlike everything above, which is launch-
  // frozen); shown on the token page header and the DEX screener.
  twitter         String?  @db.VarChar(120)
  telegram        String?  @db.VarChar(120)
  discord         String?  @db.VarChar(120)
  // pump.fun-style opt-out: false = the creator holds ZERO tokens at launch
  // (no airdrop allocation), so the coin cannot be dumped on followers
  airdropEnabled  Boolean  @default(true)
  createdAt       DateTime @default(now())
  airdropCount    Int      @default(0) // followers airdropped to (cumulative)
  // post-graduation swap indexing cursor: last pair block scanned into
  // SocialTokenTrade (null = pool never scanned). Int gives ~6y headroom at
  // this chain's ~0.1s blocks (13.9M as of 2026-07); revisit before 2.1B.
  poolSyncedBlock Int?
  // Transfer-recipient indexing cursor: last block scanned into
  // SocialTokenTransferee (null = never scanned; first sweep binary-searches
  // the token contract's creation block). Same headroom note as above.
  transferSyncedBlock Int?
  @@index([createdAt])
  @@index([creatorAddress])
}

// Every EOA that ever RECEIVED this token in a raw Transfer. The trade ledger
// only knows wallets that traded through us — a pure-transfer recipient (gift,
// external airdrop, aggregator leg) holds real tokens but never appears in
// SocialTokenTrade, so holder lists derived from the ledger alone are blind to
// them (~67 real SAGE holders were invisible when this was added, 2026-07-19).
// Contracts (pair, routers) are filtered out at insert time via getCode.
model SocialTokenTransferee {
  id           Int    @id @default(autoincrement())
  tokenAddress String @db.Char(42)
  address      String @db.Char(42)
  @@unique([tokenAddress, address])
}

// A self-serve NFT edition launched from a SAGE Social profile (artists +
// project mints). Chain is the source of truth for minted counts; this row
// powers discovery and the profile mint widget.
model SocialNftEdition {
  id              Int      @id @default(autoincrement())
  artistAddress   String   @db.Char(42)
  Artist          User     @relation("SocialEditions", fields: [artistAddress], references: [walletAddress])
  editionAddress  String   @unique @db.Char(42)
  name            String   @db.VarChar(60)
  symbol          String   @db.VarChar(12)
  imageUrl        String   // edition art (S3, compressed)
  priceEth        Float
  maxSupply       Int
  launchTxHash    String   @db.Char(66)
  createdAt       DateTime @default(now())
  // creator pressed "Stop mint": the UI hides/disables minting. (UI gate —
  // the on-chain contract keeps its hard cap regardless.)
  haltedAt        DateTime?
  @@index([artistAddress])
  @@index([createdAt])
}

// Recorded token trades (buys/sells on the SocialTokenFactory curve) — powers
// the pump.fun-style price chart, trades feed and derived holder list. The
// chain stays the source of truth for balances; this is a verified mirror.
model SocialTokenTrade {
  id           Int      @id @default(autoincrement())
  tokenAddress String   @db.Char(42)
  trader       String   @db.Char(42)
  side         String   // "buy" | "sell"
  ethAmount    Float    // ETH in (buy) or out (sell), net of fee
  tokenAmount  Float    // tokens received (buy) or sold (sell)
  priceEth     Float    // ETH per 1M tokens at this trade (for the chart)
  txHash       String   @unique @db.Char(66)
  createdAt    DateTime @default(now())
  @@index([tokenAddress, id])
  @@index([tokenAddress, trader])
}

// Per-user hide list: a wallet can hide a token / edition / owned-NFT from
// their own profile. ref is the contract or item address (lowercased).
model SocialHiddenItem {
  ownerAddress String   @db.Char(42)
  kind         String   // "token" | "edition" | "nft"
  ref          String   // address or "contract:tokenId"
  createdAt    DateTime @default(now())
  @@id([ownerAddress, kind, ref])
  @@index([ownerAddress])
}

model SocialCollect {
  id               Int        @id @default(autoincrement())
  postId           Int
  collectorAddress String     @db.Char(42)
  amount           Float      // paid to the author in `currency` (0 = free/points collect)
  currency         String     @default("SAGE") // "SAGE" | "ETH"
  pointsSpent      BigInt?    // pixels burned instead of SAGE (verified users)
  payTxHash        String?    @db.Char(66) @unique // null for free collects
  // Nullable so a row can be created as an atomic CLAIM (using the
  // @@unique([postId, collectorAddress]) below as the race guard) BEFORE the
  // slow verify-payment + on-chain-mint work runs, then filled in once
  // minting actually succeeds. Was NOT NULL, which meant the uniqueness
  // check could only ever be enforced AFTER minting already happened —
  // two concurrent requests for the same post both passed the early
  // check-then-mint sequence and both minted a real NFT, with only one
  // recorded here (see collectPost() in social.page.ts).
  mintTxHash       String?    @db.Char(66)
  contractAddress  String?    @db.Char(42) // SageNFT the token was minted into
  tokenId          Int?
  createdAt        DateTime   @default(now())
  Post             SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([postId, collectorAddress]) // one edition per wallet
  @@index([postId])
  @@index([collectorAddress])
}

// Referral gate: sign-ups (well, participation — SIWE itself is permissionless)
// require redeeming an invite code. Codes auto-provision per user; verified
// users get more. The code doubles as the share slug: /invite/{code}.
model SocialInviteCode {
  code          String   @id // e.g. SAGE-7F3K2A
  ownerAddress  String   @db.Char(42)
  Owner         User     @relation("InviteOwner", fields: [ownerAddress], references: [walletAddress])
  maxUses       Int      @default(5)
  uses          Int      @default(0)
  createdAt     DateTime @default(now())
  @@index([ownerAddress])
}

// Alpha group chat: auto-created when a user goes premium (verified). The
// owner's FOLLOWERS are the members — follow to enter, talk alpha. The owner
// can switch it off (enabled=false hides it and blocks posting).
model SocialGroupChat {
  ownerAddress String   @id @db.Char(42)
  Owner        User     @relation(fields: [ownerAddress], references: [walletAddress])
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  Messages     SocialGroupMessage[]
}

model SocialGroupMessage {
  id           Int             @id @default(autoincrement())
  ownerAddress String          @db.Char(42) // which alpha chat
  Chat         SocialGroupChat @relation(fields: [ownerAddress], references: [ownerAddress], onDelete: Cascade)
  fromAddress  String          @db.Char(42)
  text         String          @db.VarChar(1000)
  createdAt    DateTime        @default(now())
  @@index([ownerAddress, id])
}

// Wallet-to-wallet DMs. Sending is a premium (verified) feature; reading is
// free so invitees can see the messages that recruited them.
model SocialMessage {
  id          Int       @id @default(autoincrement())
  fromAddress String    @db.Char(42)
  toAddress   String    @db.Char(42)
  From        User      @relation("SocialMsgFrom", fields: [fromAddress], references: [walletAddress])
  To          User      @relation("SocialMsgTo", fields: [toAddress], references: [walletAddress])
  text        String    @db.VarChar(1000)
  createdAt   DateTime  @default(now())
  readAt      DateTime?
  @@index([toAddress, readAt])
  @@index([fromAddress, toAddress, id])
  @@index([toAddress, fromAddress, id])
}

// Off-chain pixels spend ledger: available = EarnedPoints.totalPointsEarned
// (oracle-accrued, never decremented here) minus the sum of these rows.
model SocialPointsSpend {
  id        Int      @id @default(autoincrement())
  address   String   @db.Char(42)
  User      User     @relation(fields: [address], references: [walletAddress])
  amount    BigInt   // pixels spent
  reason    String   // e.g. "collect:123"
  createdAt DateTime @default(now())
  @@index([address])
}

model Offer {
  id                       Int    @id @default(autoincrement())
  signer                   String @db.Char(42)
  nftContractAddress       String @db.Char(42)
  price                    Float
  nftId                    Int
  expiresAt                Int
  isSellOffer              Boolean
  signedOffer              String
  // Currency the offer was SIGNED in ("SAGE" | "ETH") — part of the signed
  // message on the new marketplace contract, so it must be replayed exactly.
  // ETH is only valid for sell offers (listings); buy offers are SAGE-only.
  currency                 String @default("SAGE")
  state                    OfferState @default(ACTIVE)
  Nft                      Nft   @relation(fields:[nftId], references: [id])

}

enum OfferState {
  ACTIVE
  USED
  CANCELLED
  INVALID
}

model Config {
  id              Int    @id @default(autoincrement())
  featuredDropId  Int?
  FeaturedDrop    Drop?  @relation("ConfigFeaturedDrop", fields:[featuredDropId], references:[id])
  welcomeMessage  String
  gasLimitForTxs  Int
  @@unique([featuredDropId])
}

model Follow {
  walletAddress                 String @db.Char(42)
  followedAddress               String @db.Char(42)
  @@id([walletAddress, followedAddress])  
}

enum AssetType {
  ETH_ASH // legacy name: SAGE token on Robinhood mainnet (4663)
  SAGE_TESTNET // SAGE token on Robinhood testnet (46630)
}

enum Role {
  USER
  ARTIST
  ADMIN
}

enum WhitelistType {
  WALLET
  ERC20
  ERC721
  ERC1155
  MERKLE
}

enum SaleEventType {
  LOTTERY
  AUCTION
  MARKETPLACE
}

model SaleEvent {
  id              Int    @id @default(autoincrement())
  eventType       SaleEventType
  eventId         Int    // lotteryId | auctionId | nftId
  seller          String @db.Char(42) // artistAddress
  buyer           String @db.Char(42)
  amountTokens    Float // ASH
  amountPoints    Int?
  amountUSD       Float?
  txHash          String? @db.Char(66)
  blockTimestamp  Int
}

model Refund {
  id               Int @id @default(autoincrement())
  buyer            String @db.Char(42)
  lotteryId        Int
  refundableTokens Float
  blockTimestamp   Int?
  txHash           String? @db.Char(66)
  Lottery          Lottery @relation(fields: [lotteryId], references: [id])
  @@unique([buyer,lotteryId])
}

model BidHistory {
  id                    Int        @id @default(autoincrement())
  auctionId             Int
  bidderAddress         String @db.Char(42)
  amount                Float
  blockTimestamp        Int
  Auction               Auction @relation(fields: [auctionId], references: [id])
  Bidder                User @relation(fields: [bidderAddress], references: [walletAddress])
}
// ─── Off-chain pixels ledger (migration prep, 2026-07-20) ────────────────────
// Mirrors SagePoints v3's exact streaming design so accrual needs NO writes:
// points-at-read-time = settled + min(checkpointSage, cap) × rate × elapsed.
// The keeper's job (bank the stream + reset the checkpoint when a balance
// changes) becomes a free DB update instead of a gas-costing seedSettled tx.
// Snapshot copies each wallet's on-chain (settled, checkpointSage, lastSync)
// verbatim, so the math continues seamlessly from the same state. While
// PIXELS_SOURCE=chain (the default) these tables are shadow-only.
model PixelAccount {
  walletAddress String   @id @db.Char(42)
  settled       BigInt   @default(0) // banked whole pixels
  checkpointSage BigInt  @default(0) // whole SAGE sustained since lastSync
  lastSync      DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Append-only journal — the auditability that replaces on-chain transparency.
// Every settled-balance mutation writes a row: migration snapshots, keeper
// banking, collect spends/earns, refunds, promos.
model PixelJournal {
  id            Int      @id @default(autoincrement())
  walletAddress String   @db.Char(42)
  delta         BigInt   // signed whole pixels
  kind          String   @db.VarChar(20) // snapshot|bank|spend|credit|refund
  reason        String   @db.VarChar(120)
  createdAt     DateTime @default(now())
  @@index([walletAddress, createdAt])
}

// ─── Chain-wide DEX indexer (every pair on the chain, 2026-07-20) ────────────
// The screener's native tier only knows tokens launched through OUR factory;
// these tables hold the WHOLE chain's Uniswap V2 universe (17.5k pairs on
// mainnet at build time). Discovery = PairCreated scan with a persisted
// cursor; per-pair stats/swaps sync lazily (viewed pairs) plus a bounded
// stalest-first rotation — same shapes as the pool-trade indexer.

model DexPair {
  id              Int      @id @default(autoincrement())
  pairAddress     String   @unique @db.Char(42)
  baseToken       String   @db.Char(42) // the non-WETH side
  quoteToken      String   @db.Char(42) // WETH
  baseIsToken0    Boolean
  baseName        String   @db.VarChar(80)
  baseSymbol      String   @db.VarChar(40)
  baseDecimals    Int      @default(18)
  createdAtBlock  Int
  createdAt       DateTime
  // last block whose Swap events were folded into DexSwap (null = never)
  swapSyncedBlock Int?
  // ETH per 1M base tokens — same convention as SocialTokenTrade.priceEth
  priceEth        Float    @default(0)
  liquidityEth    Float    @default(0) // WETH reserve (x1 side)
  updatedAt       DateTime @updatedAt
  @@index([baseToken])
  @@index([updatedAt])
}

model DexSwap {
  id          Int      @id @default(autoincrement())
  pairAddress String   @db.Char(42)
  logKey      String   @unique @db.VarChar(80) // txHash:logIndex — idempotent re-scans
  txHash      String   @db.Char(66)
  trader      String   @db.Char(42)
  side        String   @db.VarChar(4) // buy | sell (of the base token)
  ethAmount   Float
  tokenAmount Float
  priceEth    Float // ETH per 1M base tokens
  createdAt   DateTime
  @@index([pairAddress, createdAt])
}

// tiny cursor store for the indexer's global scans (key: 'pair-discovery')
model DexIndexState {
  key    String @id @db.VarChar(40)
  cursor Int    @default(0)
}

// cross-instance cache for the DexScreener global lookup: one row per query,
// shared by every Cloud Run instance (the in-memory memo triples upstream
// spend at 3 instances), and failures cache too (ok=false) so a 429 storm
// can't retry the same dead query every keystroke
model DexLookupCache {
  q  String   @id @db.VarChar(120)
  rows Json
  ok Boolean  @default(true)
  at DateTime @default(now())
}
