generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_CONNECTION_POOL_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Drop {
  id                               Int         @id @default(autoincrement())
  name                             String
  createdAt                        DateTime    @default(now())
  approvedAt                       DateTime?
  goLiveAt                         DateTime? // staged until this time; null = live once approved
  approvedBy                       String?     @db.Char(42)
  bannerImageS3Path                String
  description                      String
  mobileCoverS3Path                String?
  tileImageS3Path                  String?
  featuredMediaS3Path              String?
  artistAddress                    String      @db.Char(42)
  // Per-drop artist display name override. Set once at drop creation and
  // frozen — does not track later profile renames or apply to other drops
  // by the same wallet. Null = show the artist's current profile username.
  artistDisplayName                String?
  // Secondary-sale royalty in PERCENT (12 = 12%). Stamped onto the artist's
  // NFT contract as basis points at drop deploy; each token minted for this
  // drop keeps the value permanently. Marketplace re-sales only — primary
  // sale splits are unaffected.
  royaltyPercentage                Float       @default(12)
  // Payment currency for every game in this drop: "SAGE" (the ERC-20) or
  // "ETH" (native). Chosen at creation, baked into the game contracts at
  // deploy (on-chain: address(0) = SAGE, the 0xEeee..EEeE sentinel = ETH).
  currency                         String      @default("SAGE")
  // Allowlist gating: when enabled, only wallets in AllowlistEntries may
  // mint/bid/buy (on-chain via a per-drop SageWhitelist contract for open
  // editions + lotteries; UI-gate for auctions). Editable pre- and post-deploy.
  allowlistEnabled                 Boolean     @default(false)
  whitelistContractAddress         String?     @db.Char(42) // deployed SageWhitelist; null until approval
  // IP gate: minting requires claiming a spot first (one per IP, hashed) —
  // the claim auto-adds the wallet to the drop's on-chain whitelist, so
  // direct-contract mints from unclaimed wallets revert. Sybil SPEED BUMP,
  // not a wall (VPNs rotate IPs; shared IPs get one spot total).
  ipGateEnabled                    Boolean     @default(false)
  // SAGE Social follow gate: when on, anyone who follows this drop's artist
  // on SAGE Social is auto-added to the drop's allowlist (DB + on-chain).
  followGateEnabled                Boolean     @default(false)
  NftContract                      NftContract @relation("ContractDrops", fields:[artistAddress], references: [artistAddress])
  ApprovedByUser                   User?       @relation("Drop_approvedByToUser", fields: [approvedBy], references: [walletAddress])
  Auctions                         Auction[]
  Lotteries                        Lottery[]
  OpenEditions                     OpenEdition[]
  CollectionMints                  CollectionMint[]
  UserFavoriteDrops                User[]      @relation("userFavoriteDrops")
  FeaturedDropConfig               Config?     @relation("ConfigFeaturedDrop")
  AllowlistEntries                 DropAllowlistEntry[]
}

// One row per (drop, network) mint-spot claim for IP-gated drops. The IP is
// stored as a salted hash — never raw. A network gets ONE wallet per drop;
// a wallet gets ONE claim per drop.
model MintIpClaim {
  id            Int      @id @default(autoincrement())
  dropId        Int
  ipHash        String   @db.Char(64) // sha256(salt + client ip), hex
  walletAddress String   @db.Char(42)
  createdAt     DateTime @default(now())
  @@unique([dropId, ipHash])
  @@unique([dropId, walletAddress])
}

// "Collection" drop style: a ZIP of N unique images uploaded in bulk (ANS-104
// bundles + one Arweave path manifest); collectors mint sequentially at a
// fixed SAGE price via the SageCollection contract. Unlike OpenEdition there
// is no upfront Nft row per image — Nft rows materialize per mint (see
// RegisterCollectionMint), keyed off the manifest paths.
model CollectionMint {
  id               Int       @id @default(autoincrement())
  dropId           Int
  collectionId     Int? // on-chain collection id (== id, set at deploy/approval)
  contractAddress  String?   @db.Char(42)
  // Dedicated per-drop SageNFT the collection mints into, named after the
  // DROP — external marketplaces title collections by ERC-721 name(), so
  // this makes each collection drop its own marketplace collection. Null =
  // legacy (minted into the artist's shared contract, e.g. rMonet).
  nftContractAddress String? @db.Char(42)
  costTokens       Float     @default(0) // mint price in SAGE
  maxSupply        Int // number of images == hard mint cap
  limitPerUser     Int       @default(0) // 0 = unlimited
  mintCount        Int       @default(0) // cached on-chain mint count
  isLive           Boolean   @default(false)
  startTime        DateTime
  endTime          DateTime? // null = NO deadline — mint stays open until sold out
  manifestId       String? // Arweave path-manifest txid (set when processing completes)
  baseUri          String? // https://arweave.net/{manifestId}/ — token i's metadata at {i}.json
  previewImagePath String? // first image's URL, for tiles/cards
  status           String    @default("staging") // staging | processing | done | failed
  progress         String? // JSON: { imagesTotal, imagesBundled, bundlesPosted: [txids], error? }
  // JSON: { "<index>": { img: dataItemId, json: dataItemId, ext: "png" } } —
  // written as processing batches complete; doubles as the resume checkpoint
  // (DataItem ids are NOT reproducible across retries: Arweave RSA-PSS
  // signatures are randomized, so a re-signed item gets a new id) and as the
  // register-time lookup for each minted token's direct image URL.
  pathMap          String?
  Drop             Drop      @relation(fields: [dropId], references: [id])
}

model DropAllowlistEntry {
  id        Int       @id @default(autoincrement())
  dropId    Int
  address   String    @db.Char(42) // stored lowercase
  createdAt DateTime  @default(now())
  syncedAt  DateTime? // null = not yet pushed to the on-chain SageWhitelist
  Drop      Drop      @relation(fields: [dropId], references: [id])

  @@unique([dropId, address])
  @@index([dropId])
}

model Lottery {
  id                          Int        @id @default(autoincrement()) 
  dropId                      Int    
  isRefundable                Boolean    @default(false) 
  isLive                      Boolean    @default(false)
  contractAddress             String?    @db.Char(42)
  costPerTicketTokens         Float      @default(0.0)
  costPerTicketPoints         Int        @default(0)
  maxTickets                  Int        @default(0)
  maxTicketsPerUser           Int        @default(0)
  whitelistId                 Int?
  prizesAwardedAt             DateTime?
  endTime                     DateTime
  startTime                   DateTime
  Drop                        Drop       @relation(fields: [dropId], references: [id])
  Whitelist                   Whitelist?  @relation(fields: [whitelistId], references: [id])
  Nfts                        Nft[]
  PrizeProofs                 PrizeProof[]  
  Refunds                     Refund[] 
}

model OpenEdition {
  id              Int       @id @default(autoincrement())
  dropId          Int
  nftId           Int
  editionId       Int? // on-chain open edition id (set at deploy/approval)
  contractAddress String?   @db.Char(42)
  costTokens      Float     @default(0) // price per mint in SAGE
  costPoints      Int       @default(0) // price per mint in pixels
  maxPerUser      Int       @default(0) // 0 = unlimited
  mintCount       Int       @default(0) // cached on-chain mint count
  isLive          Boolean   @default(false)
  startTime       DateTime
  endTime         DateTime
  Drop            Drop      @relation(fields: [dropId], references: [id])
  Nft             Nft       @relation(fields: [nftId], references: [id])
  @@unique([nftId])
}

model Auction {
  id                    Int        @id @default(autoincrement())
  dropId                Int        
  lastUpdatedAt         DateTime?
  minimumPrice          String?
  settled               Boolean    @default(false)
  startTime             DateTime
  endTime               DateTime?
  duration              Int?
  isLive                Boolean    @default(false) 
  nftId                 Int 
  winnerAddress         String?     @db.Char(42)
  claimedAt             DateTime?
  contractAddress       String?   @db.Char(42)
  Drop                  Drop @relation(fields: [dropId], references: [id])
  Nft                   Nft  @relation(fields: [nftId], references: [id])
  Bids                  BidHistory[]
  @@unique([nftId])
}

model SplitEntry {
  id                 Int      @id @default(autoincrement())
  destinationAddress String   @db.Char(42)
  splitterId         Int
  percent            Float
  Splitter           Splitter @relation(fields: [splitterId], references: [id])
}

model Splitter {
  id                     Int          @id @default(autoincrement())
  splitterAddress        String?      @db.Char(42)
  NftContract            NftContract[] @relation("Splitter")
  SplitterEntries        SplitEntry[]
}

model Whitelist {
  id               Int              @id @default(autoincrement())
  contractAddress  String           @db.Char(42)
  targetAddress    String?          @db.Char(42)
  tokenId          Int?
  minBalance       Int?
  name             String
  Type             WhitelistType
  Lotteries        Lottery[]
}

model Nft {
  id                       Int          @id @default(autoincrement())
  tokenId                  Int?
  name                     String
  description              String
  metadataPath             String?
  arweavePath              String?
  s3Path                   String
  s3PathOptimized          String
  tags                     String?
  width                    Int?
  height                   Int?
  numberOfEditions         Int          @default(0)
  isHidden                 Boolean      @default(false)
  lotteryId                Int?
  price                    Float?
  ownerAddress             String?      @db.Char(42)
  artistAddress            String?      @db.Char(42)
  // Snapshot of the parent Drop's artistDisplayName (if any) at the moment
  // this Nft was created — frozen per-NFT for the same reason Drop's own
  // field is frozen: a later profile rename or a different drop by the same
  // wallet shouldn't retroactively change how an already-minted piece is
  // attributed. Null = fall back to the artist's live username.
  artistDisplayName        String?
  PrizeProof               PrizeProof[]
  Auction                  Auction?
  OpenEdition              OpenEdition?
  Lottery                  Lottery?     @relation(fields: [lotteryId], references: [id])
  NftContract              NftContract? @relation(fields: [artistAddress], references: [artistAddress])
  Offers                   Offer[]   
}

model NftContract {
  artistAddress          String  @id @db.Char(42)
  contractAddress        String? @db.Char(42)
  // DEPRECATED — never read; superseded by Drop.royaltyPercentage (per-drop,
  // stamped on-chain at deploy). Kept to avoid a destructive column drop.
  royaltyPercentage      Float       @default(0.0)
  splitterId             Int?
  Splitter               Splitter?   @relation("Splitter", fields: [splitterId], references: [id])
  Artist                 User        @relation("ArtistContract", fields: [artistAddress], references: [walletAddress])
  Drops                  Drop[]  @relation("ContractDrops")
  ListingNfts            Nft[] 
  @@unique([contractAddress])      
}

model PrizeProof {
  winnerAddress String    @db.Char(42)
  proof         String
  claimedAt     DateTime?
  createdAt     DateTime
  nftId         Int
  ticketNumber  Int
  lotteryId     Int
  uri           String
  Nft           Nft       @relation(fields: [nftId], references: [id])
  Lottery       Lottery   @relation(fields: [lotteryId], references: [id])
  User          User      @relation(fields: [winnerAddress], references: [walletAddress])
  @@id([lotteryId, winnerAddress, nftId])
}

model TokenTransaction {
  blockNumber    Int
  blockTimestamp Int
  from           String    @db.Char(42)
  to             String    @db.Char(42)
  value          String
  assetType      AssetType
  id             Int       @id @default(autoincrement())
  txHash         String    @db.Char(66)
  @@index([from, to])
}

model EarnedPoints {
  address           String   @id @db.Char(42)
  totalPointsEarned BigInt   @default(0)
  signedMessage     String
  updatedAt         DateTime @default(now())
  User              User     @relation(fields: [address], references: [walletAddress])
}

model RewardType {
  type               AssetType @id
  rewardRate         Float
  lastBlockInspected Int
  chainId            Int
  contract           String    @db.Char(42)
  startingBlock      Int
  positionSizeLimit  String    @default("0")
  // watermark for the pixels ACCRUAL pass (distinct from lastBlockInspected,
  // which tracks Transfer-event SCANNING): transactions at or below this
  // block are already folded into PixelAccrual rows
  pointsBlockProcessed Int     @default(0)
}

// Per-(holder, asset) pixels checkpoint. The updater used to reload the whole
// TokenTransaction table and replay every holder's full history on every run
// (unbounded, grows forever); with this it folds only NEW transfers into each
// holder's running state. `pixels` is the total accrued through `refTime`
// (the last balance change); live balances keep accruing from there.
model PixelAccrual {
  id        Int       @id @default(autoincrement())
  address   String    @db.Char(42) // lowercase holder address
  assetType AssetType
  balance   String    @default("0") // wei, decimal string
  pixels    Float     @default(0)
  refTime   Int       @default(0) // unix seconds of last balance change; 0 = none yet
  @@unique([address, assetType])
}

model User {
  walletAddress                 String        @id @db.Char(42)
  email                         String?       @db.VarChar(40)
  twitterUsername               String?       @db.VarChar(40)
  instagramUsername             String?       @db.VarChar(40)
  webpage                       String?       @db.VarChar(50)
  mediumUsername                String?       @db.VarChar(40)
  createdAt                     DateTime      @default(now())
  role                          Role          @default(USER)
  bio                           String?       @db.VarChar(1000)
  ashBalanceAtCreation          String        @default("0")
  profilePicture                String?
  country                       String?
  state                         String?
  bannerImageS3Path            	String?
  receiveEmailNotification      Boolean       @default(true)
  username                      String?       @db.VarChar(40)
  // SAGE Social verified pfp: when the avatar was picked from an owned NFT,
  // this points at it. Verification is computed at READ time (owner must
  // still match and profilePicture must still be that NFT's image), so a
  // sold NFT or a custom re-upload silently un-verifies without any cron.
  pfpNftId                      Int?
  // SAGE Social paid verification ($10 in SAGE to the platform treasury):
  // the checkmark + premium features (sell/collect posts, points-collect,
  // boost, DMs). Posting stays free.
  verifiedAt                    DateTime?
  verifiedTxHash                String?       @db.Char(66)
  // Referral gate: the invite code this wallet redeemed to join SAGE Social.
  // Null + role USER + unverified = can browse but not post yet.
  invitedByCode                 String?
  SocialInviteCodes             SocialInviteCode[] @relation("InviteOwner")
  SocialMessagesSent            SocialMessage[]    @relation("SocialMsgFrom")
  SocialMessagesReceived        SocialMessage[]    @relation("SocialMsgTo")
  SocialPointsSpends            SocialPointsSpend[]
  DropsApproved                 Drop[]        @relation("Drop_approvedByToUser")
  NftContract                   NftContract?  @relation("ArtistContract")
  EarnedPoints                  EarnedPoints?
  FavoriteDrops                 Drop[]        @relation("userFavoriteDrops")
  Bids                          BidHistory[]
  PrizeProofs                   PrizeProof[]
  // SAGE Social: wallet == identity for the BlueSky-style network
  SocialPosts                   SocialPost[]    @relation("SocialAuthor")
  SocialLikes                   SocialLike[]
  SocialReposts                 SocialRepost[]
  Following                     SocialFollow[]  @relation("SocialFollower")
  Followers                     SocialFollow[]  @relation("SocialFollowing")
  @@index([walletAddress])
  @@unique([username])
}

// ─────────────────────────── SAGE Social ───────────────────────────
// A wallet-native BlueSky clone: identity is the SIWE wallet, posts can be
// tipped in SAGE tokens, and avatars are the user's (NFT) profilePicture.

model SocialPost {
  id           Int            @id @default(autoincrement())
  authorAddress String        @db.Char(42)
  Author       User           @relation("SocialAuthor", fields: [authorAddress], references: [walletAddress])
  text         String         @db.VarChar(500)
  imageUrl     String?        // optional media (arweave/S3 URL)
  createdAt    DateTime       @default(now())
  // reply threading (self-relation); null = top-level post
  replyToId    Int?
  ReplyTo      SocialPost?    @relation("SocialReplies", fields: [replyToId], references: [id], onDelete: Cascade)
  Replies      SocialPost[]   @relation("SocialReplies")
  // denormalized counters kept in sync on write (cheap reads on the feed)
  likeCount    Int            @default(0)
  repostCount  Int            @default(0)
  replyCount   Int            @default(0)
  tipTotal     Float          @default(0) // total SAGE tipped to this post
  // burn-to-boost: SAGE burned (sent to 0x…dEaD) pins the post to the top of
  // the global feed until boostedUntil. Verified on-chain server-side.
  boostedUntil DateTime?
  boostBurned  Float          @default(0) // lifetime SAGE burned on this post
  // collect-as-NFT: author sets a SAGE price (0 = free collect); each collect
  // pays the author directly and server-mints the post into the platform's
  // "SAGE Social" SageNFT contract.
  collectPrice Float?
  collectCount Int            @default(0)
  Likes        SocialLike[]
  Reposts      SocialRepost[]
  Tips         SocialTip[]
  Boosts       SocialBoost[]
  Collects     SocialCollect[]
  @@index([createdAt])
  @@index([authorAddress])
  @@index([replyToId])
  @@index([boostedUntil])
}

model SocialFollow {
  followerAddress  String   @db.Char(42)
  followingAddress String   @db.Char(42)
  createdAt        DateTime @default(now())
  Follower         User     @relation("SocialFollower", fields: [followerAddress], references: [walletAddress])
  Following        User     @relation("SocialFollowing", fields: [followingAddress], references: [walletAddress])
  @@id([followerAddress, followingAddress])
  @@index([followingAddress])
}

model SocialLike {
  postId       Int
  userAddress  String     @db.Char(42)
  createdAt    DateTime   @default(now())
  Post         SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  User         User       @relation(fields: [userAddress], references: [walletAddress])
  @@id([postId, userAddress])
}

model SocialRepost {
  postId       Int
  userAddress  String     @db.Char(42)
  createdAt    DateTime   @default(now())
  Post         SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  User         User       @relation(fields: [userAddress], references: [walletAddress])
  @@id([postId, userAddress])
}

model SocialTip {
  id          Int        @id @default(autoincrement())
  postId      Int
  fromAddress String     @db.Char(42)
  toAddress   String     @db.Char(42)
  amount      Float      // SAGE amount
  txHash      String     @db.Char(66) @unique // one credit per on-chain transfer
  createdAt   DateTime   @default(now())
  Post        SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@index([postId])
}

model SocialBoost {
  id          Int        @id @default(autoincrement())
  postId      Int
  fromAddress String     @db.Char(42)
  amount      Float      // SAGE burned
  hours       Float      // boost duration this burn bought
  txHash      String     @db.Char(66) @unique // one credit per on-chain burn
  createdAt   DateTime   @default(now())
  Post        SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@index([postId])
}

model SocialCollect {
  id               Int        @id @default(autoincrement())
  postId           Int
  collectorAddress String     @db.Char(42)
  amount           Float      // SAGE paid to the author (0 = free/points collect)
  pointsSpent      BigInt?    // pixels burned instead of SAGE (verified users)
  payTxHash        String?    @db.Char(66) @unique // null for free collects
  mintTxHash       String     @db.Char(66)
  contractAddress  String     @db.Char(42) // SageNFT the token was minted into
  tokenId          Int
  createdAt        DateTime   @default(now())
  Post             SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([postId, collectorAddress]) // one edition per wallet
  @@index([postId])
  @@index([collectorAddress])
}

// Referral gate: sign-ups (well, participation — SIWE itself is permissionless)
// require redeeming an invite code. Codes auto-provision per user; verified
// users get more. The code doubles as the share slug: /invite/{code}.
model SocialInviteCode {
  code          String   @id // e.g. SAGE-7F3K2A
  ownerAddress  String   @db.Char(42)
  Owner         User     @relation("InviteOwner", fields: [ownerAddress], references: [walletAddress])
  maxUses       Int      @default(5)
  uses          Int      @default(0)
  createdAt     DateTime @default(now())
  @@index([ownerAddress])
}

// Wallet-to-wallet DMs. Sending is a premium (verified) feature; reading is
// free so invitees can see the messages that recruited them.
model SocialMessage {
  id          Int       @id @default(autoincrement())
  fromAddress String    @db.Char(42)
  toAddress   String    @db.Char(42)
  From        User      @relation("SocialMsgFrom", fields: [fromAddress], references: [walletAddress])
  To          User      @relation("SocialMsgTo", fields: [toAddress], references: [walletAddress])
  text        String    @db.VarChar(1000)
  createdAt   DateTime  @default(now())
  readAt      DateTime?
  @@index([toAddress, readAt])
  @@index([fromAddress, toAddress, id])
  @@index([toAddress, fromAddress, id])
}

// Off-chain pixels spend ledger: available = EarnedPoints.totalPointsEarned
// (oracle-accrued, never decremented here) minus the sum of these rows.
model SocialPointsSpend {
  id        Int      @id @default(autoincrement())
  address   String   @db.Char(42)
  User      User     @relation(fields: [address], references: [walletAddress])
  amount    BigInt   // pixels spent
  reason    String   // e.g. "collect:123"
  createdAt DateTime @default(now())
  @@index([address])
}

model Offer {
  id                       Int    @id @default(autoincrement())
  signer                   String @db.Char(42)
  nftContractAddress       String @db.Char(42)
  price                    Float
  nftId                    Int
  expiresAt                Int
  isSellOffer              Boolean
  signedOffer              String
  // Currency the offer was SIGNED in ("SAGE" | "ETH") — part of the signed
  // message on the new marketplace contract, so it must be replayed exactly.
  // ETH is only valid for sell offers (listings); buy offers are SAGE-only.
  currency                 String @default("SAGE")
  state                    OfferState @default(ACTIVE)
  Nft                      Nft   @relation(fields:[nftId], references: [id])

}

enum OfferState {
  ACTIVE
  USED
  CANCELLED
  INVALID
}

model Config {
  id              Int    @id @default(autoincrement())
  featuredDropId  Int?
  FeaturedDrop    Drop?  @relation("ConfigFeaturedDrop", fields:[featuredDropId], references:[id])
  welcomeMessage  String
  gasLimitForTxs  Int
  @@unique([featuredDropId])
}

model Follow {
  walletAddress                 String @db.Char(42)
  followedAddress               String @db.Char(42)
  @@id([walletAddress, followedAddress])  
}

enum AssetType {
  ETH_ASH // legacy name: SAGE token on Robinhood mainnet (4663)
  SAGE_TESTNET // SAGE token on Robinhood testnet (46630)
}

enum Role {
  USER
  ARTIST
  ADMIN
}

enum WhitelistType {
  WALLET
  ERC20
  ERC721
  ERC1155
  MERKLE
}

enum SaleEventType {
  LOTTERY
  AUCTION
  MARKETPLACE
}

model SaleEvent {
  id              Int    @id @default(autoincrement())
  eventType       SaleEventType
  eventId         Int    // lotteryId | auctionId | nftId
  seller          String @db.Char(42) // artistAddress
  buyer           String @db.Char(42)
  amountTokens    Float // ASH
  amountPoints    Int?
  amountUSD       Float?
  txHash          String? @db.Char(66)
  blockTimestamp  Int
}

model Refund {
  id               Int @id @default(autoincrement())
  buyer            String @db.Char(42)
  lotteryId        Int
  refundableTokens Float
  blockTimestamp   Int?
  txHash           String? @db.Char(66)
  Lottery          Lottery @relation(fields: [lotteryId], references: [id])
  @@unique([buyer,lotteryId])
}

model BidHistory {
  id                    Int        @id @default(autoincrement())
  auctionId             Int
  bidderAddress         String @db.Char(42)
  amount                Float
  blockTimestamp        Int
  Auction               Auction @relation(fields: [auctionId], references: [id])
  Bidder                User @relation(fields: [bidderAddress], references: [walletAddress])
}